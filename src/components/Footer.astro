---
import { siteConfig } from '../config/site';
import Container from './Container.astro';

const year = new Date().getFullYear();
---

<footer class="border-t border-black/10 py-12">
  <Container class="flex flex-col gap-8 sm:flex-row sm:items-start sm:justify-between">
    <div class="flex flex-col gap-2">
      <span class="font-serif text-xl text-zinc-900">{siteConfig.name}</span>
      <span class="text-sm" style="color: var(--color-muted)">{siteConfig.title}</span>
    </div>

    <nav class="flex flex-wrap gap-x-6 gap-y-2" aria-label="Footer">
      {siteConfig.nav.map((item) => (
        <a href={item.href} class="text-sm text-zinc-900/70 hover:text-zinc-900 transition-colors">
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex flex-col gap-2 text-sm" style="color: var(--color-muted)">
      <a href={`mailto:${siteConfig.email}`} class="hover:text-zinc-900 transition-colors">
        {siteConfig.email}
      </a>
      <a href={`tel:${siteConfig.phone}`} class="hover:text-zinc-900 transition-colors">
        {siteConfig.phoneDisplay}
      </a>
    </div>
  </Container>

  <Container class="mt-10 border-t border-black/10 pt-6">
    <p class="text-xs" style="color: var(--color-muted)">
      &copy; {year} {siteConfig.name}. All rights reserved.
    </p>
  </Container>
</footer>
