---
import { skills } from '../data/skills';
---

<div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
  {skills.map((group, i) => (
    <div
      class="reveal rounded-2xl border border-white/10 p-6"
      style={`background: var(--color-surface); animation-delay:${i * 80}ms;`}
      data-reveal
    >
      <h3 class="mb-4 text-sm font-semibold uppercase tracking-[0.15em] text-[var(--color-accent)]">
        {group.category}
      </h3>
      <ul class="flex flex-wrap gap-2">
        {group.items.map((item) => (
          <li class="rounded-full px-3 py-1.5 text-sm text-white/85" style="background: rgba(255,255,255,0.06); border: 1px solid var(--color-border-subtle);">
            {item}
          </li>
        ))}
      </ul>
    </div>
  ))}
</div>
