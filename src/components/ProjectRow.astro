---
import { Image } from 'astro:assets';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  reverse?: boolean;
  index: number;
  priority?: boolean;
}

const { project, reverse = false, index, priority = false } = Astro.props;
---

<article class="grid grid-cols-1 items-center gap-10 lg:grid-cols-12 lg:gap-10">
  <a
    href={project.url}
    target="_blank"
    rel="noopener noreferrer"
    class:list={[
      'shine group relative block overflow-hidden rounded-2xl border border-black/10 shadow-[0_20px_50px_-24px_rgba(0,0,0,0.25)] transition-all duration-500 hover:-translate-y-1.5 hover:shadow-[0_30px_60px_-24px_rgba(0,0,0,0.35)] lg:col-span-8',
      reverse ? 'lg:order-2' : 'lg:order-1',
    ]}
    aria-label={`Visit the live ${project.name} website`}
    data-reveal
    data-reveal-type="mask"
  >
    <div class="relative aspect-[4/3] overflow-hidden" style="background: var(--color-surface);">
      <Image
        src={project.image}
        alt={`Screenshot of the ${project.name} website`}
        width={1200}
        height={900}
        loading={priority ? 'eager' : 'lazy'}
        data-gsap-parallax
        class="h-full w-full scale-[1.12] object-cover transition-transform duration-700 ease-out group-hover:scale-[1.16]"
      />
      <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-black/60 via-black/0 to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
      <span class="pointer-events-none absolute bottom-5 right-5 flex translate-y-2 items-center gap-1.5 rounded-full bg-white px-4 py-2 text-xs font-semibold text-black opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100">
        Visit Website
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </span>
    </div>
  </a>

  <div
    class:list={['flex flex-col gap-5 lg:col-span-4', reverse ? 'lg:order-1' : 'lg:order-2']}
    data-reveal
    data-reveal-type="stagger"
  >
    <div class="flex items-center gap-3">
      <span class="font-mono text-xs" style="color: var(--color-accent)">{String(index).padStart(2, '0')}</span>
      <span class="h-px w-6" style="background: var(--color-border-strong)"></span>
      <span class="eyebrow">{project.category}</span>
    </div>

    <h3 class="font-serif text-3xl text-zinc-900 sm:text-4xl">{project.name}</h3>

    <p class="text-base leading-relaxed" style="color: var(--color-muted)">{project.description}</p>

    <dl class="grid grid-cols-1 gap-4 border-t pt-5 hairline">
      <div class="flex flex-col gap-1">
        <dt class="eyebrow" style="color: var(--color-muted)">Role</dt>
        <dd class="text-sm text-zinc-900/85">{project.role}</dd>
      </div>
      <div class="flex flex-col gap-1">
        <dt class="eyebrow" style="color: var(--color-muted)">Challenge</dt>
        <dd class="text-sm text-zinc-900/85">{project.goal}</dd>
      </div>
      <div class="flex flex-col gap-1">
        <dt class="eyebrow" style="color: var(--color-muted)">Solution</dt>
        <dd class="text-sm text-zinc-900/85">{project.contribution}</dd>
      </div>
      <div class="flex flex-col gap-1">
        <dt class="eyebrow" style="color: var(--color-muted)">Results</dt>
        <dd class="text-sm text-zinc-900/85">{project.results}</dd>
      </div>
    </dl>

    <div class="flex flex-wrap gap-2">
      {project.technologies.map((tech) => (
        <span class="rounded-full px-3 py-1 text-xs font-medium text-zinc-900/80" style="background: rgba(0,0,0,0.04); border: 1px solid var(--color-border-subtle);">
          {tech}
        </span>
      ))}
    </div>

    <a
      href={project.url}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-2 inline-flex w-fit items-center gap-1.5 text-sm font-semibold text-zinc-900 transition-colors hover:text-[var(--color-accent)]"
    >
      Visit Website
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
    </a>
  </div>
</article>

<style>
  .shine {
    position: relative;
  }
  .shine::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(115deg, transparent 40%, rgba(255, 255, 255, 0.16) 50%, transparent 60%);
    background-size: 250% 250%;
    background-position: -100% -100%;
    transition: background-position 0.9s ease;
    pointer-events: none;
  }
  .shine:hover::after {
    background-position: 100% 100%;
  }
</style>
