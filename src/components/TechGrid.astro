---
import { techCategories } from '../data/techLogos';
---

<div class="flex flex-col divide-y" style="border-color: var(--border-color);">
  {techCategories.map((cat, i) => (
    <div
      class="capability-row reveal grid grid-cols-1 gap-6 rounded-xl py-8 transition-colors duration-300 sm:grid-cols-12 sm:items-start sm:-mx-6 sm:px-6"
      data-reveal
      data-reveal-type="fade-up"
      style={`animation-delay:${i * 60}ms;`}
    >
      <div class="flex items-start gap-4 sm:col-span-5">
        <span class="font-mono text-sm" style="color: var(--brand-primary);">{String(i + 1).padStart(2, '0')}</span>
        <span
          class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full"
          style="background: var(--brand-lavender); color: var(--brand-primary);"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" set:html={cat.icon} />
        </span>
        <div class="flex flex-col gap-1">
          <h3 class="text-lg font-semibold" style="color: var(--text-primary);">{cat.category}</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-secondary); max-width: none;">{cat.description}</p>
        </div>
      </div>

      <div class="flex flex-wrap gap-x-6 gap-y-3 sm:col-span-7 sm:pt-1">
        {cat.items.map((tool) => (
          <div class="flex items-center gap-2.5">
            <span class="flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full border" style="background: var(--surface-white); border-color: var(--border-color);">
              {tool.path ? (
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="currentColor" style="color: var(--brand-primary);" set:html={`<path d="${tool.path}"/>`} />
              ) : (
                <span class="text-[10px] font-semibold" style="color: var(--brand-primary);">{tool.name.charAt(0)}</span>
              )}
            </span>
            <span class="text-sm font-medium" style="color: var(--text-primary);">{tool.name}</span>
          </div>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .capability-row:hover {
    background: var(--brand-soft);
  }
</style>
