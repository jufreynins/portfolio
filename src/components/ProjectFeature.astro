---
import { Image } from 'astro:assets';
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  layout: 'full' | 'left' | 'right';
  index: number;
}

const { project, layout, index } = Astro.props;
const isFull = layout === 'full';
const isRight = layout === 'right';
---

<article
  class:list={[
    'project-feature group',
    isFull ? 'flex flex-col gap-8' : 'grid grid-cols-1 items-center gap-10 lg:grid-cols-12 lg:gap-12',
  ]}
>
  <a
    href={project.url}
    target="_blank"
    rel="noopener noreferrer"
    aria-label={`Visit the live ${project.name} website`}
    class:list={[
      'relative block overflow-hidden rounded-2xl',
      isFull ? 'aspect-[21/9]' : 'aspect-[4/3] lg:col-span-7',
      isRight ? 'lg:order-2' : '',
    ]}
    style="background: var(--surface-warm);"
    data-reveal
    data-reveal-type="mask"
  >
    <Image
      src={project.image}
      alt={`Screenshot of the ${project.name} website`}
      width={1600}
      height={900}
      loading={index === 1 ? 'eager' : 'lazy'}
      class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05]"
    />
    <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-[var(--brand-ink)]/55 via-transparent to-transparent opacity-0 transition-opacity duration-500 group-hover:opacity-100"></div>
    <span class="pointer-events-none absolute bottom-5 right-5 flex translate-y-2 items-center gap-1.5 rounded-full px-4 py-2 text-xs font-bold opacity-0 transition-all duration-300 group-hover:translate-y-0 group-hover:opacity-100" style="background: var(--surface-white); color: var(--brand-ink);">
      Visit Website
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
    </span>
  </a>

  <div class:list={['flex flex-col gap-4', isFull ? 'max-w-2xl' : 'lg:col-span-5', isRight ? 'lg:order-1' : '']} data-reveal data-reveal-type="stagger">
    <div class="flex items-center gap-3">
      <span class="font-mono text-xs" style="color: var(--brand-primary);">{String(index).padStart(2, '0')}</span>
      <span class="eyebrow">{project.category}</span>
    </div>

    <h3 class="project-feature-title relative w-fit text-2xl sm:text-3xl">{project.name}</h3>

    <p class="leading-relaxed" style="color: var(--text-secondary);">{project.results}</p>

    <div class="mt-2 flex flex-wrap gap-4">
      <button
        type="button"
        data-view-details
        data-project-slug={project.slug}
        class="inline-flex items-center gap-1.5 text-sm font-bold transition-colors duration-300"
        style="color: var(--brand-primary);"
      >
        View Details
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover:translate-x-1"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </button>
      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 text-sm font-bold transition-colors duration-300"
        style="color: var(--text-primary);"
      >
        Visit Website
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>
    </div>
  </div>

  <template data-project-template={project.slug}>
    <div class="flex flex-col gap-6">
      <div class="relative aspect-[16/9] overflow-hidden rounded-2xl" style="background: var(--surface-warm);">
        <Image
          src={project.image}
          alt={`Screenshot of the ${project.name} website`}
          width={1200}
          height={675}
          loading="lazy"
          class="h-full w-full object-cover"
        />
      </div>

      <div class="flex flex-col gap-2">
        <span class="eyebrow">{project.category}</span>
        <h3 class="text-3xl" style="color: var(--text-primary);">{project.name}</h3>
        <p class="leading-relaxed" style="color: var(--text-secondary);">{project.description}</p>
      </div>

      <dl class="grid grid-cols-1 gap-5 border-t pt-6 hairline sm:grid-cols-2">
        <div class="flex flex-col gap-1.5">
          <dt class="eyebrow" style="color: var(--text-secondary);">Role</dt>
          <dd class="text-sm" style="color: var(--text-primary);">{project.role}</dd>
        </div>
        <div class="flex flex-col gap-1.5">
          <dt class="eyebrow" style="color: var(--text-secondary);">Challenge</dt>
          <dd class="text-sm" style="color: var(--text-primary);">{project.goal}</dd>
        </div>
        <div class="flex flex-col gap-1.5">
          <dt class="eyebrow" style="color: var(--text-secondary);">Solution</dt>
          <dd class="text-sm" style="color: var(--text-primary);">{project.contribution}</dd>
        </div>
        <div class="flex flex-col gap-1.5">
          <dt class="eyebrow" style="color: var(--text-secondary);">Results</dt>
          <dd class="text-sm" style="color: var(--text-primary);">{project.results}</dd>
        </div>
      </dl>

      <div class="flex flex-wrap gap-2">
        {project.technologies.map((tech) => (
          <span class="rounded-full px-3 py-1 text-xs font-medium" style="background: var(--surface-warm); border: 1px solid var(--border-color); color: var(--text-primary);">
            {tech}
          </span>
        ))}
      </div>

      <a
        href={project.url}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-2 inline-flex w-fit min-h-[48px] items-center justify-center gap-1.5 rounded-full px-6 text-[0.9375rem] font-bold transition-colors duration-300"
        style="background: var(--brand-primary); color: var(--text-on-dark);"
      >
        Visit Website
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="7" y1="17" x2="17" y2="7"/><polyline points="7 7 17 7 17 17"/></svg>
      </a>
    </div>
  </template>
</article>

<style>
  .project-feature-title::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -4px;
    height: 2px;
    width: 0;
    background: var(--brand-primary);
    transition: width 0.3s ease;
  }
  .project-feature:hover .project-feature-title::after {
    width: 100%;
  }
</style>
