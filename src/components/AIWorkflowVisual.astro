---
const stages = [
  {
    label: 'Requirements',
    human: true,
    icon: '<path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><path d="M14 2v6h6"/><path d="M9 13h6M9 17h6"/>',
  },
  {
    label: 'AI Exploration',
    human: false,
    icon: '<path d="M12 3v3M12 18v3M5.6 5.6l2.1 2.1M16.3 16.3l2.1 2.1M3 12h3M18 12h3M5.6 18.4l2.1-2.1M16.3 7.7l2.1-2.1"/><circle cx="12" cy="12" r="3.2"/>',
  },
  {
    label: 'Human Review',
    human: true,
    icon: '<circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-7 8-7s8 2.6 8 7"/>',
  },
  {
    label: 'Development',
    human: false,
    icon: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  },
  {
    label: 'Testing',
    human: true,
    icon: '<path d="M12 2 4 6v6c0 5 3.4 8.7 8 10 4.6-1.3 8-5 8-10V6Z"/><path d="M9 12l2 2 4-4"/>',
  },
  {
    label: 'Delivery',
    human: true,
    icon: '<path d="M4 12l6 6L20 6"/>',
  },
];
---

<div class="hidden lg:block">
  <div class="relative" data-ai-progress-track>
    <div class="absolute left-0 right-0 top-[22px] h-0.5" style="background: var(--border-color);"></div>
    <div class="absolute left-0 top-[22px] h-0.5 w-full origin-left" data-ai-progress style="background: var(--brand-primary);"></div>

    <div class="relative grid grid-cols-6 gap-3">
      {stages.map((stage) => (
        <div class="ai-step group relative flex flex-col items-center gap-3 text-center" data-ai-step data-human={stage.human ? 'true' : 'false'}>
          <span class="ai-node relative z-10 flex h-11 w-11 items-center justify-center rounded-full transition-all duration-500">
            <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={stage.icon} />
          </span>
          <div class="flex flex-col gap-0.5">
            <span class="text-xs font-semibold" style="color: var(--text-primary);">{stage.label}</span>
            <span class="eyebrow text-[9px]" style="color: var(--text-secondary);">{stage.human ? 'Human' : 'AI'}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<div class="flex flex-col gap-6 lg:hidden" data-reveal data-reveal-type="stagger">
  {stages.map((stage, i) => (
    <div class="flex items-center gap-4">
      <span
        class="flex h-11 w-11 flex-shrink-0 items-center justify-center rounded-full"
        style={`background: ${stage.human ? 'var(--brand-primary)' : 'var(--brand-lavender)'}; color: ${stage.human ? 'var(--text-on-dark)' : 'var(--brand-primary)'};`}
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" set:html={stage.icon} />
      </span>
      <div class="flex items-center gap-2">
        <span class="text-sm font-semibold" style="color: var(--text-primary);">{stage.label}</span>
        <span class="eyebrow text-[9px]" style="color: var(--text-secondary);">{stage.human ? 'Human' : 'AI'}</span>
      </div>
    </div>
  ))}
</div>

<style>
  .ai-node {
    background: var(--surface-white);
    border: 2px dashed var(--border-color);
    color: var(--text-secondary);
  }
  [data-human='true'] .ai-node {
    border-style: solid;
  }
  .ai-step.is-active .ai-node {
    border-color: var(--brand-primary);
    color: var(--brand-primary);
    background: var(--brand-lavender);
  }
  .ai-step.is-active[data-human='true'] .ai-node {
    background: var(--brand-primary);
    color: var(--text-on-dark);
    border-color: var(--brand-primary);
  }
</style>
