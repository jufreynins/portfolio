---
interface Props {
  eyebrow?: string;
  title: string;
  description?: string;
  align?: 'left' | 'center';
  as?: 'h2' | 'h1';
}

const { eyebrow, title, description, align = 'left', as: Tag = 'h2' } = Astro.props;

const alignClass = align === 'center' ? 'text-center items-center mx-auto' : 'text-left items-start';
---

<div class:list={['reveal flex flex-col gap-4 max-w-2xl', alignClass]} data-reveal>
  {eyebrow && (
    <span class="text-xs font-semibold uppercase tracking-[0.2em] text-accent" style="color: var(--color-accent)">
      {eyebrow}
    </span>
  )}
  <Tag class="text-3xl sm:text-4xl md:text-5xl font-bold tracking-tight text-white text-balance">
    {title}
  </Tag>
  {description && (
    <p class="text-base sm:text-lg leading-relaxed" style="color: var(--color-muted)">
      {description}
    </p>
  )}
</div>
