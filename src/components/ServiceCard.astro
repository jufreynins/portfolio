---
import type { Service } from '../data/services';

interface Props {
  service: Service;
  delay?: number;
}

const { service, delay = 0 } = Astro.props;
---

<div
  class="reveal group relative flex flex-col gap-4 rounded-2xl border border-white/10 p-6 transition-all duration-400 hover:-translate-y-1 hover:border-white/25"
  style={`background: var(--color-surface); animation-delay:${delay}ms;`}
  data-reveal
>
  <div
    class="flex h-11 w-11 items-center justify-center rounded-xl border border-white/10 text-[var(--color-accent)] transition-transform duration-300 group-hover:scale-110"
    style="background: linear-gradient(135deg, rgba(110,231,255,0.12), rgba(167,139,250,0.12));"
    aria-hidden="true"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M9 12l2 2 4-4"/></svg>
  </div>
  <h3 class="text-base font-bold text-white">{service.title}</h3>
  <p class="text-sm leading-relaxed" style="color: var(--color-muted)">{service.description}</p>
</div>
